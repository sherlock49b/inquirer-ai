#!/usr/bin/env bash
set -e

ROOT="$(git rev-parse --show-toplevel)"

# Detect which languages have staged changes
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
RUN_PY=false; RUN_GO=false; RUN_TS=false; RUN_RS=false

for f in $CHANGED_FILES; do
  case "$f" in
    python/*) RUN_PY=true ;;
    go/*)     RUN_GO=true ;;
    typescript/*) RUN_TS=true ;;
    rust/*)   RUN_RS=true ;;
    spec/*|.githooks/*|.github/*) RUN_PY=true; RUN_GO=true; RUN_TS=true; RUN_RS=true ;;
  esac
done

if ! $RUN_PY && ! $RUN_GO && ! $RUN_TS && ! $RUN_RS; then
  echo "pre-commit: no language files changed, skipping checks"
  exit 0
fi

PIDS=()
LOGS=()
NAMES=()
FAIL=0

run_check() {
  local name="$1" logfile="$2"
  shift 2
  "$@" >"$logfile" 2>&1 &
  PIDS+=($!)
  LOGS+=("$logfile")
  NAMES+=("$name")
}

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# Launch checks in parallel — only for changed languages
if $RUN_PY; then
  run_check "python" "$TMPDIR/py.log" bash -c "
    cd '$ROOT/python'
    echo '=== ruff check ===' && uv run ruff check src/ tests/ &&
    echo '=== ruff format ===' && uv run ruff format --check src/ tests/ &&
    echo '=== pyright ===' && uv run pyright src/ &&
    echo '=== pytest ===' && uv run pytest tests/ -q
  "
fi

if $RUN_GO; then
  run_check "go" "$TMPDIR/go.log" bash -c "
    cd '$ROOT/go'
    UNFORMATTED=\$(gofmt -l ./prompt/ ./examples/)
    if [ -n \"\$UNFORMATTED\" ]; then
      echo \"Files need gofmt: \$UNFORMATTED\"; exit 1
    fi
    echo '=== vet ===' && go vet ./prompt/ ./examples/... &&
    echo '=== test ===' && go test ./prompt/ -count=1 -short
  "
fi

if $RUN_TS; then
  run_check "typescript" "$TMPDIR/ts.log" bash -c "
    cd '$ROOT/typescript'
    echo '=== tsc ===' && npx tsc --noEmit &&
    echo '=== biome ===' && npx biome check src/ tests/ &&
    echo '=== vitest ===' && npx vitest run
  "
fi

if $RUN_RS; then
  run_check "rust" "$TMPDIR/rs.log" bash -c "
    cd '$ROOT/rust'
    echo '=== fmt ===' && cargo fmt -- --check &&
    echo '=== clippy ===' && cargo clippy -- -D warnings &&
    echo '=== test ===' && cargo test --quiet
  "
fi

# Wait for all and collect results
for i in "${!PIDS[@]}"; do
  if ! wait "${PIDS[$i]}"; then
    FAIL=1
    echo "pre-commit: [${NAMES[$i]}] FAILED"
    cat "${LOGS[$i]}"
  else
    echo "pre-commit: [${NAMES[$i]}] OK"
  fi
done

exit $FAIL
