#!/usr/bin/env bash
set -e

cd "$(git rev-parse --show-toplevel)/python"

echo "pre-push: ruff check..."
uv run ruff check src/ tests/

echo "pre-push: ruff format..."
uv run ruff format --check src/ tests/

echo "pre-push: pyright (strict)..."
uv run pyright src/

echo "pre-push: full test suite with coverage..."
uv run pytest tests/ -v --cov=inquirer_ai --cov-report=term-missing
